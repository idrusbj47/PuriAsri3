
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inventaris RT — Puri Asri 3 RT 01 / RW 12</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --green-950: #0d1f10; --green-900: #132b17; --green-800: #1e4225;
      --green-700: #265930; --green-600: #2e7038; --green-500: #3a8c45;
      --gold-700: #7a5c1e; --gold-500: #c49a3c; --gold-100: #f8f0da;
      --cream-bg: #f7f5f0; --cream-card: #fdfcfa;
      --text-dark: #1a2b1c; --text-muted: #6b8570;
      --border-light: rgba(46,112,56,0.12); --border-mid: rgba(46,112,56,0.22);
      --shadow-card: 0 2px 12px rgba(30,66,37,0.08);
    }
    body { font-family: 'DM Sans', sans-serif; background: var(--cream-bg); color: var(--text-dark); min-height: 100vh; display: flex; flex-direction: column; }
    header { background: var(--green-800); padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; height: 64px; }
    .header-title { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 600; color: #fff; }
    .header-sub { font-size: 11px; color: var(--green-200); text-transform: uppercase; }
    main { flex: 1; max-width: 960px; margin: 0 auto; width: 100%; padding: 40px 24px; }
    .hero { text-align: center; margin-bottom: 40px; }
    .hero-title { font-family: 'Playfair Display', serif; font-size: 36px; color: var(--green-900); margin-bottom: 16px; }
    .cutoff-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--gold-100); padding: 5px 14px; border-radius: 20px; font-size: 11px; color: var(--gold-700); font-weight: 500; }
    .inv-table { width: 100%; border-collapse: collapse; background: var(--cream-card); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow-card); }
    .inv-table th, .inv-table td { padding: 16px; text-align: left; border-bottom: 1px solid var(--border-light); }
    .inv-table th { background: var(--green-50); color: var(--green-800); font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; }
    .inv-table td { font-size: 14px; }
    @media (max-width: 600px) { .inv-table { display: block; overflow-x: auto; } }
  </style>
</head>
<body>
  <header>
    <div class="header-brand">
      <div class="header-title">Puri Asri 3</div>
      <div class="header-sub">RT 01 · RW 12 · Inventaris</div>
    </div>
  </header>
  <main id="mainContent">
    <div class="hero">
      <h1 class="hero-title">Daftar Inventaris RT</h1>
      <div id="cutoffContainer"></div>
    </div>
    <table class="inv-table">
      <thead>
        <tr><th>No</th><th>Nama Inventaris</th><th>Jumlah</th><th>Keterangan</th></tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
  </main>
  <script>
    const CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vT3AcxgyXE2lhGdxWuq3EhzyRCVRS8tWe5HhKXT6OpC2V2dCZ3LqZt85mGbBI7LUC-IzHoWTbyYUCox/pub?gid=1378010647&single=true&output=csv';
    
    async function loadData() {
      try {
        const response = await fetch(CSV_URL);
        const text = await response.text();
        const lines = text.trim().split('\n');
        
        // Cek baris pertama untuk Cut Off
        const cutoffLine = lines[0].split(',');
        const cutoffDate = cutoffLine[cutoffLine.length - 1].replace(/"/g, '').trim();
        document.getElementById('cutoffContainer').innerHTML = `<div class="cutoff-badge">Data per: ${cutoffDate}</div>`;

        // Baris ke-2 header
        const rows = lines.slice(2);
        const tbody = document.getElementById('tableBody');
        rows.forEach(line => {
          const cols = line.split(',');
          if(cols.length >= 4) {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td>${cols[0]}</td><td>${cols[1]}</td><td>${cols[2]}</td><td>${cols[3]}</td>`;
            tbody.appendChild(tr);
          }
        });
      } catch(e) { console.error(e); }
    }
    loadData();
  </script>
</body>
</html>
